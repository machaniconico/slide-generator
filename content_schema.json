{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "スライド資料生成用のコンテンツスキーマ",
  "type": "object",
  "required": ["title_top", "title_mid", "title_bottom", "subtitle", "sections", "closing_quote"],
  "properties": {
    "title_top": {
      "type": "string",
      "description": "表紙タイトル上段（2-4文字推奨）",
      "maxLength": 6
    },
    "title_mid": {
      "type": "string",
      "description": "表紙タイトル中段（4-6文字推奨）",
      "maxLength": 8
    },
    "title_bottom": {
      "type": "string",
      "description": "表紙タイトル下段（4-6文字推奨）",
      "maxLength": 8
    },
    "subtitle": {
      "type": "string",
      "description": "サブタイトル（20文字以内推奨）",
      "maxLength": 30
    },
    "sections": {
      "type": "array",
      "description": "セクション（3つ固定）",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["number", "name", "slides"],
        "properties": {
          "number": {
            "type": "string",
            "description": "セクション番号（01, 02, 03）"
          },
          "name": {
            "type": "string",
            "description": "セクション名（7文字以内推奨）",
            "maxLength": 10
          },
          "slides": {
            "type": "array",
            "description": "セクション内のスライドデータ",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["overview", "cards", "stats", "timeline"]
                },
                "title_top": { "type": "string", "description": "2文字以内", "maxLength": 4 },
                "title_bottom": { "type": "string", "description": "6文字以内", "maxLength": 8 },
                "subtitle": { "type": "string", "maxLength": 15 },
                "detail": { "type": "string", "description": "40文字以内推奨", "maxLength": 50 },
                "body": { "type": "string", "description": "30文字以内推奨", "maxLength": 40 },
                "title": { "type": "string", "maxLength": 15 },
                "cards": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": { "type": "string" },
                    "minItems": 2,
                    "maxItems": 2,
                    "description": "[タイトル(6文字以内), 説明(15文字以内)]"
                  }
                },
                "stats": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": { "type": "string" },
                    "minItems": 2,
                    "maxItems": 2,
                    "description": "[数値(5文字以内), ラベル(10文字以内)]"
                  }
                },
                "timeline": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": { "type": "string" },
                    "minItems": 3,
                    "maxItems": 3,
                    "description": "[年号, 見出し(8文字以内), 説明(12文字以内)]"
                  }
                }
              }
            }
          }
        }
      }
    },
    "closing_quote": {
      "type": "string",
      "description": "クロージングメッセージ（20文字以内推奨）",
      "maxLength": 30
    }
  }
}
